---
import { PERSON_JSONLD } from "../lib/jsonld";
import { THEME_BOOT } from "../lib/themeBoot";
import type { Locale } from "../lib/t";
import "../styles/global.css";

interface Props {
  locale: Locale;
  title: string;
  description: string;
  /** Path under /en/ or /uk/ excluding the locale prefix, e.g. "" or "about/". */
  pathSuffix?: string;
  ogImage?: string;
  /** OpenGraph type — "website" (default) or "article" for blog posts. */
  ogType?: string;
  /** Root-relative href of an RSS feed to advertise via <link rel="alternate">. */
  feedHref?: string;
  /** ISO timestamps for article OG metadata (emitted only when ogType="article"). */
  publishedTime?: string;
  modifiedTime?: string;
}

const {
  locale,
  title,
  description,
  pathSuffix = "",
  ogImage,
  ogType = "website",
  feedHref,
  publishedTime,
  modifiedTime,
} = Astro.props;

const htmlLang = locale === "uk" ? "uk-UA" : "en";

const siteOrigin = Astro.site
  ? Astro.site.origin
  : "https://roman-kocherezhchenko.com";

const canonicalPath = `/${locale}/${pathSuffix}`;
const canonicalUrl = `${siteOrigin}${canonicalPath}`;

// hreflang alternates — every locale plus x-default mapped to en.
const localeAlternates: Array<{ hreflang: string; href: string }> = [
  { hreflang: "en", href: `${siteOrigin}/en/${pathSuffix}` },
  { hreflang: "uk", href: `${siteOrigin}/uk/${pathSuffix}` },
  { hreflang: "x-default", href: `${siteOrigin}/en/${pathSuffix}` },
];

// Per-locale font subset. Latin (en) and Cyrillic-Ukrainian (uk) subsets are
// shipped from public/fonts/. Preload only the primary subset for the active
// locale; the @font-face declarations in global.css carry unicode-range so the
// browser will additionally fetch the other subset only if a glyph requires it.
// Loaded with `font-display: optional` to avoid CLS (AC16).
const fontHref =
  locale === "uk" ? "/fonts/inter-cyr-uk.woff2" : "/fonts/inter-latin.woff2";

const ogLocale = locale === "uk" ? "uk_UA" : "en_US";
const ogImageUrl = ogImage ?? `${siteOrigin}/og-default.png`;
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {/* Apply the stored theme before first paint (no FOUC). Inline + CSP-hashed
        via SCRIPT_HASHES; rerun `npm run csp:hash` if THEME_BOOT changes. */}
    <script is:inline set:html={THEME_BOOT} />

    <meta name="theme-color" content="#0b0d10" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fafafa" media="(prefers-color-scheme: light)" />
    <meta name="color-scheme" content="dark light" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    {
      localeAlternates.map((alt) => (
        <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
      ))
    }

    {
      feedHref && (
        <link
          rel="alternate"
          type="application/rss+xml"
          title={title}
          href={feedHref}
        />
      )
    }

    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href={fontHref}
      crossorigin
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Roman Kocherezhchenko — AI-Enabled Engineer" />
    {
      ogType === "article" && publishedTime && (
        <meta property="article:published_time" content={publishedTime} />
      )
    }
    {
      ogType === "article" && modifiedTime && (
        <meta property="article:modified_time" content={modifiedTime} />
      )
    }

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="Roman Kocherezhchenko — AI-Enabled Engineer" />

    <script type="application/ld+json" set:html={PERSON_JSONLD} is:inline />
  </head>
  <body>
    <slot />
  </body>
</html>
