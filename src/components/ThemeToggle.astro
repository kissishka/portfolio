---
import type { Locale } from "../lib/t";
import { t } from "../lib/t";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const label = t("theme.toggle", locale);
---

{/*
  Button-only progressive enhancement. CSS keeps it hidden unless scripting is
  available (`:root[data-js]`); the icon shown reflects the active theme via the
  same dark-first logic as the palette. The toggle logic ships as an external
  module (CSP `script-src 'self'`), mirroring the language switcher.
*/}
<button
  type="button"
  class="theme-toggle"
  data-theme-toggle
  aria-label={label}
  aria-pressed="true"
>
  <svg
    class="icon icon-sun"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path
      d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"
    ></path>
  </svg>
  <svg
    class="icon icon-moon"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z"></path>
  </svg>
</button>

<script src="/scripts/theme-toggle.js" type="module" defer is:inline></script>
