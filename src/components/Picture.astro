---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  alt: string;
  widths?: number[];
  sizes?: string;
  /** Hero image — set true on the LCP candidate so it loads eagerly. */
  priority?: boolean;
  class?: string;
}

const {
  src,
  alt,
  widths = [320, 640, 960, 1280],
  sizes = "(max-width: 768px) 100vw, 960px",
  priority = false,
  class: className,
} = Astro.props;
---

<Image
  src={src}
  alt={alt}
  widths={widths}
  sizes={sizes}
  format="avif"
  loading={priority ? "eager" : "lazy"}
  decoding="async"
  fetchpriority={priority ? "high" : "auto"}
  class={className}
/>
