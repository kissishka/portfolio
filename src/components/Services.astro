---
import { getCollection } from "astro:content";
import type { Locale } from "../lib/t";
import { t } from "../lib/t";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const all = await getCollection("services", (entry) =>
  entry.id.startsWith(`${locale}/`),
);
const services = all.sort((a, b) => a.data.order - b.data.order);
---

<section class="services" aria-labelledby="services-heading">
  <div class="section-head">
    <h2 id="services-heading">{t("services.heading", locale)}</h2>
    <p class="section-intro">{t("services.intro", locale)}</p>
  </div>
  <ol class="service-list">
    {
      services.map((entry, i) => (
        <li class="service" data-service={entry.data.key}>
          <span class="service__index" aria-hidden="true">
            {String(i + 1).padStart(2, "0")}
          </span>
          <div class="service__body">
            <h3 class="service__title">{entry.data.title}</h3>
            <p class="service__scope">{entry.data.scope}</p>
            <p class="service__deliverable">{entry.data.deliverable}</p>
          </div>
          {entry.data.startingPrice && (
            <p class="service__price">
              <span class="service__price-label">
                {t("services.startingPrice", locale)}
              </span>
              {entry.data.startingPrice}
            </p>
          )}
        </li>
      ))
    }
  </ol>
</section>
