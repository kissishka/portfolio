---
import { getCollection } from "astro:content";
import type { Locale } from "../lib/t";
import { t } from "../lib/t";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const all = await getCollection("portfolio", (entry) =>
  entry.id.startsWith(`${locale}/`),
);
const entries = all.sort((a, b) => a.data.order - b.data.order);
---

<section class="portfolio" aria-labelledby="portfolio-heading">
  <div class="section-head">
    <h2 id="portfolio-heading">{t("portfolio.heading", locale)}</h2>
    <p class="section-intro">{t("portfolio.intro", locale)}</p>
  </div>
  <ul class="case-list">
    {
      entries.map((entry) => (
        <li class="case" data-portfolio-status={entry.data.status}>
          <div class="case__head">
            <h3 class="case__title">{entry.data.title}</h3>
            {entry.data.status === "stub" ? (
              <span class="badge">{t("portfolio.stubBadge", locale)}</span>
            ) : entry.data.link ? (
              <a href={entry.data.link} rel="noopener">
                {entry.data.link}
              </a>
            ) : null}
          </div>
          <p class="case__summary">{entry.data.summary}</p>
        </li>
      ))
    }
  </ul>
</section>
