---
import type { Locale } from "../lib/t";
import { t } from "../lib/t";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

{/*
  Full-site search (⌘K / Ctrl+K). Button + native <dialog> ship in the static
  HTML but stay hidden until `:root[data-js]` is set — search needs scripting, so
  the no-JS baseline simply omits it (the blog index + tag pages already give a
  scriptless way to find posts). The <dialog> gives Esc-to-close, a focus trap,
  and backdrop dismissal for free. Logic is an external module (covered by
  `script-src 'self'`), mirroring the theme toggle and language switcher.
*/}
<button
  type="button"
  class="search-open"
  data-search-open
  aria-label={t("search.open", locale)}
  aria-keyshortcuts="Control+K Meta+K"
>
  <svg
    class="icon"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="11" cy="11" r="7"></circle>
    <path d="m21 21-4.3-4.3"></path>
  </svg>
  <kbd class="search-open__hint" data-search-keyhint aria-hidden="true">⌘K</kbd>
</button>

<dialog
  class="search"
  data-search
  data-locale={locale}
  aria-label={t("search.label", locale)}
>
  <form class="search__box" role="search">
    <svg
      class="icon"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <circle cx="11" cy="11" r="7"></circle>
      <path d="m21 21-4.3-4.3"></path>
    </svg>
    <input
      type="search"
      class="search__input"
      data-search-input
      placeholder={t("search.placeholder", locale)}
      aria-label={t("search.label", locale)}
      role="combobox"
      aria-expanded="false"
      aria-controls="search-results"
      aria-autocomplete="list"
      autocomplete="off"
      spellcheck="false"
      autofocus
    />
    <kbd class="search__esc" aria-hidden="true">Esc</kbd>
  </form>
  <ul
    class="search__results"
    id="search-results"
    data-search-results
    role="listbox"
    aria-label={t("search.label", locale)}
  >
  </ul>
  <p class="search__empty" data-search-empty hidden>
    {t("search.noResults", locale)}
  </p>
</dialog>

<script src="/scripts/search.js" type="module" defer is:inline></script>
