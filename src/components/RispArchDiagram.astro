---
// Animated dependency-flow diagram of risp's internals. Pure inline SVG + CSS,
// zero JS — CSP-safe on this strict-policy static site. Motion is animated
// stroke-dashoffset (the "current down the wire" look) plus a pulsing glow on
// the Value hub, all gated behind prefers-reduced-motion. Themed via CSS vars +
// currentColor, so it retints with dark/light automatically.
import type { Locale } from "../lib/t";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

// Only descriptive words are translated; code identifiers (St::Eval, Rc<RefCell>,
// fib(30), --features jit, Nil/Bool/Int…) are language-neutral and stay literal.
const L = {
  en: {
    a11yTitle: "risp interpreter architecture",
    a11yDesc:
      "Source text flows through the reader into a single homoiconic Value enum. The Value hub feeds the macro expander, the environment, and the evaluator, which dispatches to three engines — a tree-walker, a bytecode VM, and a Cranelift JIT — that all share one error type, one native builtin table, and one Lisp prelude, and are kept honest by a differential oracle.",
    source: "source",
    reader: "reader",
    readerParser: "explicit-stack parser",
    value: "Value enum",
    valueAst: "AST ≡ runtime value",
    macro: "macro expander",
    macroForms: "unevaluated forms",
    env: "environment",
    envDrop: "iterative 2-path drop",
    eval: "evaluator · CEK",
    evalHeap: "heap frame-stack",
    evalStack: "Rust stack: 3 frames",
    tree: "tree-walker",
    treeOracle: "reference oracle",
    vm: "bytecode VM",
    vmBeats: "beats CPython 3.14",
    jit: "Cranelift JIT",
    deopt: "deopt",
    oracle: "agree()",
    shared: "shared core — every engine sees the same world",
  },
  uk: {
    a11yTitle: "Архітектура інтерпретатора risp",
    a11yDesc:
      "Вихідний текст тече через читача в єдиний гомоіконний enum Value. Хаб Value живить макророзширювач, середовище та обчислювач, який диспетчеризує до трьох рушіїв — деревного обхідника, байткодової ВМ та Cranelift JIT — що поділяють один тип помилки, одну нативну таблицю та один Lisp-прелюд і звіряються диференційним оракулом.",
    source: "код",
    reader: "читач",
    readerParser: "парсер на явному стеку",
    value: "enum Value",
    valueAst: "AST ≡ значення",
    macro: "макророзширювач",
    macroForms: "невобчислені форми",
    env: "середовище",
    envDrop: "ітеративний 2-шляховий drop",
    eval: "обчислювач · CEK",
    evalHeap: "купний стек кадрів",
    evalStack: "стек Rust: 3 кадри",
    tree: "деревний обхідник",
    treeOracle: "еталонний оракул",
    vm: "байткодова ВМ",
    vmBeats: "випереджає CPython 3.14",
    jit: "Cranelift JIT",
    deopt: "deopt",
    oracle: "agree()",
    shared: "спільне ядро — кожен рушій бачить той самий світ",
  },
}[locale];
---

<figure class="diagram">
  <svg
    viewBox="0 0 1100 660"
    role="img"
    aria-labelledby="archdiag-t archdiag-d"
    class="archdiag"
    preserveAspectRatio="xMidYMid meet"
  >
    <title id="archdiag-t">{L.a11yTitle}</title>
    <desc id="archdiag-d">{L.a11yDesc}</desc>

    <defs>
      <!-- one shared neon glow; expanded region so the halo never clips -->
      <filter id="softglow" x="-60%" y="-60%" width="220%" height="220%">
        <feGaussianBlur stdDeviation="3.2" result="b" />
        <feMerge>
          <feMergeNode in="b" />
          <feMergeNode in="b" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
      <marker
        id="arrow"
        viewBox="0 0 10 10"
        refX="8"
        refY="5"
        markerWidth="6"
        markerHeight="6"
        orient="auto-start-reverse"
      >
        <path d="M0,0 L10,5 L0,10 z" fill="var(--flow)" />
      </marker>
    </defs>

    <!-- ============ EDGES (rail underneath, animated flow on top) ============ -->
    <g class="edges">
      <!-- text → reader -->
      <path class="rail" d="M136,320 L176,320" />
      <path class="flow" d="M136,320 L176,320" />
      <!-- reader → value -->
      <path class="rail" d="M352,320 L412,320" />
      <path class="flow" d="M352,320 L412,320" />
      <!-- value → evaluator -->
      <path class="rail" d="M608,320 L668,320" />
      <path class="flow" d="M608,320 L668,320" />
      <!-- value → macro (up) -->
      <path class="rail" d="M510,246 L510,184" />
      <path class="flow" d="M510,246 L510,184" />
      <!-- macro → evaluator (expansion re-enters eval) -->
      <path class="rail" d="M608,124 C688,124 758,196 758,252" />
      <path class="flow" d="M608,124 C688,124 758,196 758,252" />
      <!-- value → environment (down) -->
      <path class="rail" d="M510,394 L510,456" />
      <path class="flow" d="M510,394 L510,456" />
      <!-- environment → evaluator -->
      <path class="rail" d="M608,516 C688,516 758,452 758,388" />
      <path class="flow" d="M608,516 C688,516 758,452 758,388" />
      <!-- evaluator → tree-walker -->
      <path class="rail" d="M848,320 C876,320 876,196 904,196" />
      <path class="flow" d="M848,320 C876,320 876,196 904,196" />
      <!-- evaluator → bytecode VM -->
      <path class="rail" d="M848,320 C876,320 876,342 904,342" />
      <path class="flow" d="M848,320 C876,320 876,342 904,342" />
      <!-- evaluator → JIT -->
      <path class="rail" d="M848,320 C876,320 876,488 904,488" />
      <path class="flow" d="M848,320 C876,320 876,488 904,488" />
    </g>

    <!-- deopt back-edge between VM and JIT -->
    <path
      class="flow flow--deopt"
      d="M984,388 L984,442"
      marker-start="url(#arrow)"
      marker-end="url(#arrow)"
    />
    <text class="t-tag" x="998" y="419">{L.deopt}</text>

    <!-- differential-oracle bracket linking the three engines -->
    <path class="oracle" d="M1080,196 L1086,196 L1086,488 L1080,488" />
    <text class="t-oracle" x="1090" y="346" transform="rotate(90 1090 346)"
      >{L.oracle}</text
    >

    <!-- ============ NODES ============ -->

    <!-- SOURCE -->
    <g class="node">
      <rect class="nd" x="16" y="276" width="120" height="88" rx="9" />
      <text class="t-title" x="32" y="302">{L.source}</text>
      <line class="div" x1="30" y1="312" x2="122" y2="312" />
      <text class="t-code" x="32" y="332">;; risp</text>
      <text class="t-code" x="32" y="350">(map f xs)</text>
    </g>

    <!-- READER -->
    <g class="node">
      <rect class="nd" x="176" y="258" width="176" height="124" rx="9" />
      <text class="t-title" x="192" y="284">{L.reader}</text>
      <line class="div" x1="190" y1="294" x2="338" y2="294" />
      <text class="t-code" x="192" y="314">tokenizer · Vec&lt;Token&gt;</text>
      <text class="t-line" x="192" y="336">{L.readerParser}</text>
      <text class="t-code" x="192" y="358">'x → (quote x)</text>
    </g>

    <!-- MACRO -->
    <g class="node">
      <rect class="nd" x="412" y="64" width="196" height="120" rx="9" />
      <text class="t-title" x="428" y="90">{L.macro}</text>
      <line class="div" x1="426" y1="100" x2="594" y2="100" />
      <text class="t-line" x="428" y="120">{L.macroForms}</text>
      <text class="t-code" x="428" y="142">quasiquote · depth</text>
      <text class="t-code" x="428" y="164">gensym {"{g 0}"}</text>
    </g>

    <!-- VALUE — the hub -->
    <g class="node">
      <rect class="hub-halo" x="412" y="246" width="196" height="148" rx="11" />
      <rect class="nd nd--hub" x="412" y="246" width="196" height="148" rx="11" />
      <text class="t-title t-title--hub" x="428" y="274">{L.value}</text>
      <line class="div div--hub" x1="426" y1="284" x2="594" y2="284" />
      <text class="t-code" x="428" y="306">Nil Bool Int Float</text>
      <text class="t-code" x="428" y="328">Sym Str Pair(Rc)</text>
      <text class="t-code" x="428" y="350">Closure Macro Builtin</text>
      <text class="t-line t-line--accent" x="428" y="376">{L.valueAst}</text>
    </g>

    <!-- ENVIRONMENT -->
    <g class="node">
      <rect class="nd" x="412" y="456" width="196" height="120" rx="9" />
      <text class="t-title" x="428" y="482">{L.env}</text>
      <line class="div" x1="426" y1="492" x2="594" y2="492" />
      <text class="t-code" x="428" y="512">Rc&lt;RefCell&gt; chain</text>
      <text class="t-code" x="428" y="534">lookup define set!</text>
      <text class="t-line" x="428" y="556">{L.envDrop}</text>
    </g>

    <!-- EVALUATOR -->
    <g class="node">
      <rect class="nd" x="668" y="252" width="180" height="136" rx="9" />
      <text class="t-title" x="684" y="278">{L.eval}</text>
      <line class="div" x1="682" y1="288" x2="834" y2="288" />
      <text class="t-code" x="684" y="308">St::Eval / St::Ret</text>
      <text class="t-line" x="684" y="330">{L.evalHeap}</text>
      <text class="t-line" x="684" y="352">{L.evalStack}</text>
      <text class="t-code" x="684" y="374">TCO in tail call</text>
    </g>

    <!-- TREE-WALKER -->
    <g class="node">
      <rect class="nd nd--engine" x="904" y="150" width="160" height="92" rx="9" />
      <text class="t-title" x="920" y="176">{L.tree}</text>
      <line class="div" x1="918" y1="186" x2="1050" y2="186" />
      <text class="t-line" x="920" y="206">{L.treeOracle}</text>
      <text class="t-code" x="920" y="228">fib(30) · 1682 ms</text>
    </g>

    <!-- BYTECODE VM -->
    <g class="node">
      <rect class="nd nd--engine" x="904" y="296" width="160" height="92" rx="9" />
      <text class="t-title" x="920" y="322">{L.vm}</text>
      <line class="div" x1="918" y1="332" x2="1050" y2="332" />
      <text class="t-line" x="920" y="352">{L.vmBeats}</text>
      <text class="t-code t-code--accent" x="920" y="374">fib(30) · 95 ms</text>
    </g>

    <!-- CRANELIFT JIT -->
    <g class="node">
      <rect class="nd nd--engine nd--jit" x="904" y="442" width="160" height="92" rx="9" />
      <text class="t-title" x="920" y="468">{L.jit}</text>
      <line class="div" x1="918" y1="478" x2="1050" y2="478" />
      <text class="t-code" x="920" y="498">--features jit</text>
      <text class="t-code t-code--accent" x="920" y="520">6.3 ms · 10–23×</text>
    </g>

    <!-- SHARED CORE band -->
    <g class="node">
      <rect class="nd nd--shared" x="176" y="602" width="888" height="44" rx="9" />
      <text class="t-shared" x="196" y="622">{L.shared}</text>
      <text class="t-code" x="196" y="638"
        >RispError · BuiltinFn table · prelude.lisp (fold → map · filter)</text
      >
    </g>
  </svg>
</figure>

<style>
  .diagram {
    margin: 0;
  }

  .archdiag {
    display: block;
    width: 100%;
    height: auto;
    /* local theme hooks — retint automatically via the page's CSS vars */
    --wire: var(--border-2);
    --flow: var(--accent);
    overflow: visible;
  }

  /* ---- edges ---- */
  .rail {
    fill: none;
    stroke: var(--wire);
    stroke-width: 2;
    opacity: 0.45;
  }
  .flow {
    fill: none;
    stroke: var(--flow);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-dasharray: 6 12;
  }
  .flow--deopt {
    stroke-width: 1.6;
    stroke-dasharray: 4 5;
    opacity: 0.85;
  }
  .oracle {
    fill: none;
    stroke: var(--wire);
    stroke-width: 1.4;
    stroke-dasharray: 3 4;
    opacity: 0.7;
  }

  /* ---- nodes ---- */
  .nd {
    fill: var(--bg-2);
    stroke: var(--border);
    stroke-width: 1;
  }
  .nd--engine {
    stroke: var(--border-2);
  }
  .nd--hub {
    stroke: var(--flow);
    stroke-width: 1.6;
  }
  .nd--jit {
    stroke-dasharray: 5 4; /* opt-in / feature-flagged: drawn as a dashed border */
  }
  .nd--shared {
    fill: none;
    stroke: var(--border);
    stroke-dasharray: 2 5;
  }
  .hub-halo {
    fill: var(--flow);
    opacity: 0.06;
  }

  .div {
    stroke: var(--wire);
    stroke-width: 1;
    opacity: 0.45;
  }
  .div--hub {
    stroke: var(--flow);
    opacity: 0.4;
  }

  /* ---- text ---- */
  .archdiag text {
    font-family: var(--font-mono);
    fill: var(--fg-3);
  }
  .t-title {
    fill: var(--fg);
    font-size: 15px;
    letter-spacing: 0.01em;
  }
  .t-title--hub {
    fill: var(--fg);
  }
  .t-line {
    font-size: 11.5px;
    fill: var(--fg-2);
  }
  .t-line--accent,
  .t-code--accent {
    fill: var(--flow);
  }
  .t-code {
    font-size: 11.5px;
    fill: var(--fg-3);
  }
  .t-tag {
    font-size: 10.5px;
    fill: var(--flow);
  }
  .t-oracle {
    font-size: 11px;
    fill: var(--fg-3);
    text-anchor: middle;
    letter-spacing: 0.04em;
  }
  .t-shared {
    fill: var(--fg-2);
    font-size: 12px;
    letter-spacing: 0.02em;
  }

  /* ---- motion (gated) ---- */
  @media (prefers-reduced-motion: no-preference) {
    .flow {
      animation: arch-flow 1.1s linear infinite;
    }
    .flow--deopt {
      animation: arch-flow 1.4s linear infinite reverse;
    }
    .nd--hub {
      filter: url(#softglow);
    }
    .hub-halo {
      animation: arch-pulse 3s ease-in-out infinite;
      transform-box: fill-box;
      transform-origin: center;
    }
    .node {
      transition:
        transform 160ms ease,
        filter 160ms ease;
    }
    .node:hover .nd,
    .node:focus-within .nd {
      filter: url(#softglow);
    }
  }

  @keyframes arch-flow {
    to {
      stroke-dashoffset: -18;
    }
  }
  @keyframes arch-pulse {
    0%,
    100% {
      opacity: 0.05;
      transform: scale(1);
    }
    50% {
      opacity: 0.13;
      transform: scale(1.02);
    }
  }

  /* on small screens the diagram just scales down with its viewBox — keep it
     scrollable rather than reflowing a hand-authored coordinate grid */
  @media (max-width: 40rem) {
    .diagram {
      overflow-x: auto;
    }
    .archdiag {
      min-width: 640px;
    }
  }
</style>
