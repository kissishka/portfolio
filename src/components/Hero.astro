---
import type { Locale } from "../lib/t";
import { t } from "../lib/t";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<section class="hero" aria-labelledby="hero-heading">
  <p class="kicker">{t("hero.kicker", locale)}</p>
  <h1 id="hero-heading">{t("hero.headline", locale)}</h1>
  <p class="lede">{t("hero.lede", locale)}</p>
</section>
