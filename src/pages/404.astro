---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

// Cloudflare Pages serves this as dist/404.html for ANY unmatched route, so the
// visitor's locale is unknown here. Keep the page bilingual (en + uk) and link
// to both home pages. The 404 HTTP status keeps it out of search indexes, so the
// canonical/hreflang emitted by BaseLayout are immaterial. The header hides its
// language switcher (langSwitcher={false}) because there is no twin route to map.
const locale = "en" as const;
---

<BaseLayout
  locale={locale}
  title="404 — Page not found · Сторінку не знайдено"
  description="The page you’re looking for doesn’t exist or has moved."
  pathSuffix="404/"
>
  <SiteHeader locale={locale} langSwitcher={false} />
  <main>
    <section class="hero">
      <p class="kicker">404</p>
      <h1>Page not found</h1>
      <p class="lede">The page you’re looking for doesn’t exist or has moved.</p>
      <p class="lede" lang="uk">
        Сторінка, яку ви шукаєте, не існує або була переміщена.
      </p>
      <div class="cta-row">
        <a class="btn btn--primary" href="/en/">Go to homepage</a>
        <a class="btn btn--secondary" href="/uk/" lang="uk">На головну</a>
      </div>
    </section>
  </main>
  <SiteFooter locale={locale} />
</BaseLayout>
